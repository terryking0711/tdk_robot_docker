FROM osrf/ros:humble-desktop-full

ENV DEBIAN_FRONTEND=noninteractive
ENV ROS_DISTRO=humble
ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8

SHELL ["/bin/bash", "-c"]

# Basic tools + ROS build tools
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    wget \
    vim \
    nano \
    tmux \
    htop \
    net-tools \
    iputils-ping \
    usbutils \
    udev \
    python3-pip \
    python3-rosdep \
    python3-colcon-common-extensions \
    python3-vcstool \
    python3-argcomplete \
    build-essential \
    cmake \
    gdb \
    && rm -rf /var/lib/apt/lists/*

# ROS common dependencies for your project
RUN apt-get update && apt-get install -y --no-install-recommends \
    ros-humble-navigation2 \
    ros-humble-nav2-bringup \
    ros-humble-slam-toolbox \
    ros-humble-cartographer \
    ros-humble-cartographer-ros \
    ros-humble-gazebo-ros-pkgs \
    ros-humble-gazebo-ros2-control \
    ros-humble-robot-state-publisher \
    ros-humble-joint-state-publisher \
    ros-humble-joint-state-publisher-gui \
    ros-humble-xacro \
    ros-humble-tf2-tools \
    ros-humble-tf-transformations \
    ros-humble-rviz2 \
    ros-humble-teleop-twist-keyboard \
    ros-humble-ros2-control \
    ros-humble-ros2-controllers \
    ros-humble-controller-manager \
    ros-humble-twist-mux \
    ros-humble-rmw-cyclonedds-cpp \
    && rm -rf /var/lib/apt/lists/*

# Optional: serial / hardware related packages
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3-serial \
    ros-humble-serial-driver \
    ros-humble-diagnostic-updater \
    && rm -rf /var/lib/apt/lists/*

# rosdep init may already exist in base image, so ignore failure
RUN rosdep init 2>/dev/null || true
RUN rosdep update || true

# Create user matching host uid/gid at runtime is complicated.
# For now use root inside container for device access simplicity.
WORKDIR /workspaces

COPY docker/entrypoint.sh /entrypoint.sh
COPY docker/bashrc /root/.bashrc

RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
CMD ["bash"]